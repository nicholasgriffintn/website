{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nicholasgriffin-notifications",
  "compatibility_date": "2026-06-15",
  "workers_dev": false,
  "preview_urls": false,
  "main": "src/index.ts",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "notifications.nicholasgriffin.dev",
      "custom_domain": true
    }
  ],
  "dev": {
    "port": 8785
  },
  "services": [
    {
      "binding": "EMAIL_SERVICE",
      "service": "nicholasgriffin-emails"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": false
    }
  }
}
