{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "website-blog-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-24",
  "workers_dev": false,
  "preview_urls": false,
  "dev": {
    "port": 8787
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "blog",
      "preview_bucket_name": "blog"
    }
  ],
  "queues": {
    "consumers": [
      {
        "queue": "blog-update",
        "max_batch_size": 100,
        "max_batch_timeout": 5
      }
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "personal-web",
      "database_id": "cabaa840-522a-42e0-86f4-6309cfdacc79"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": false
    }
  }
}
