{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nicholasgriffin-emails",
  "compatibility_date": "2026-02-24",
  "workers_dev": false,
  "preview_urls": false,
  "main": "src/index.ts",
  "compatibility_flags": ["nodejs_compat"],
  "dev": {
    "port": 8784
  },
  "send_email": [
    {
      "name": "EMAIL"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "emails",
      "preview_bucket_name": "emails"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": false
    }
  }
}
