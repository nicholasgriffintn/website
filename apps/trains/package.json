{
  "name": "@your-scope/train-kafka-capture-cdk",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "train-kafka-capture-cdk": "dist/bin/app.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cdk": "cdk",
