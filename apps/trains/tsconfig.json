{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "aws-lambda"]
  },
  "ts-node": {
    "esm": true,
    "experimentalResolver": true
  },
  "include": ["bin/**/*.ts", "src/**/*.ts"]
}
